# Resend (Email Delivery)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Resend sender — must be verified domain in Resend dashboard
# Format: "Display Name <email@domain.com>"
RESEND_FROM_EMAIL="Hammock Property Inspections <scott@hammockpropertyinspections.com>"

# Where form submissions get emailed TO
CONTACT_EMAIL=scott@hammockpropertyinspections.com

# Supabase (Submission Storage)
# Get from: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# Site URL (used for email links)
NEXT_PUBLIC_SITE_URL=https://hammockpropertyinspections.com

# Analytics (optional — leave blank to disable)
# Google Analytics: Get Measurement ID from https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity: Get Project ID from https://clarity.microsoft.com → Settings → Overview
NEXT_PUBLIC_CLARITY_ID=
